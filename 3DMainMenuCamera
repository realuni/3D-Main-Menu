local originalStorePos = storeFrame.Position
local originalGpInfoPos = gpInfoTemplate.Position

-----------------------------------------
-- Button cooldown system
-----------------------------------------

local buttonCooldowns = {}
local COOLDOWN_TIME = 1.5 -- seconds cooldown per button

local function canClick(button)
	if buttonCooldowns[button] or isTweening then
		return false
	else
		buttonCooldowns[button] = true
		delay(COOLDOWN_TIME, function()
			buttonCooldowns[button] = nil
		end)
		return true
	end
end

local function connectButtonWithCooldown(button, callback)
	if button and button:IsA("TextButton") then
		button.MouseButton1Click:Connect(function()
			if canClick(button) then
				callback()
			end
		end)
	end
end

-----------------------------------------
-- Gamepass purchase system variables
-----------------------------------------

local currentGamepassID = nil
local purchaseButton = gpInfoTemplate:FindFirstChild("Purchase")

-----------------------------------------
-- Update GP Info Template fields and Purchase button on GP button click
-----------------------------------------

for _, gpButton in ipairs(storeFrame.Gamepasses:GetChildren()) do
	if gpButton:IsA("TextButton") then
		connectButtonWithCooldown(gpButton, function()
			-- Update GpInfoTemplate labels
			local descValue = gpButton:FindFirstChild("GamepassDescription")
			local nameValue = gpButton:FindFirstChild("GamepassName")
			local priceValue = gpButton:FindFirstChild("GamepassPrice")

			local gpDescLabel = gpInfoTemplate:FindFirstChild("GamepassDescription")
			local gpNameLabel = gpInfoTemplate:FindFirstChild("GamepassName")
			local gpPriceLabel = gpInfoTemplate:FindFirstChild("GamepassPrice")

			if gpDescLabel then
				gpDescLabel.Text = (descValue and descValue.Value) or "No description"
			end
			if gpNameLabel then
				gpNameLabel.Text = (nameValue and nameValue.Value) or "Unknown Gamepass"
			end
			if gpPriceLabel then
				gpPriceLabel.Text = tostring((priceValue and priceValue.Value) or 0)
			end

			-- Store GamepassID
			local gamepassIDValue = gpButton:FindFirstChild("GamepassID")
			if gamepassIDValue and gamepassIDValue:IsA("NumberValue") then
				currentGamepassID = gamepassIDValue.Value
			else
				currentGamepassID = nil
				warn("GamepassID NumberValue missing on clicked GP button")
			end

			-- Check ownership async and update purchase button text and state
			spawn(function()
				local owned = false
				if currentGamepassID then
					local success, result = pcall(function()
						return MarketplaceService:UserOwnsGamePassAsync(player.UserId, currentGamepassID)
					end)
					if success then
						owned = result
					else
						warn("Failed to check ownership:", result)
					end
				end

				pcall(function()
					if owned then
						purchaseButton.Text = "OWNED"
						purchaseButton.Active = false
					else
						purchaseButton.Text = "PURCHASE"
						purchaseButton.Active = true
					end
				end)
			end)

			-- Show gpInfoTemplate sliding in, slide store out
			gpInfoTemplate.Visible = true
			local tweenOut = tweenFrame(storeFrame, UDim2.new(-1, 0, originalStorePos.Y.Scale, originalStorePos.Y.Offset))
			local tweenIn = tweenFrame(gpInfoTemplate, UDim2.new(0, 4, 0, 4))

			tweenFramesWithLock({tweenOut, tweenIn}, function()
				storeFrame.Visible = false
			end)
		end)
	end
end

-----------------------------------------
-- Purchase button click handling
-----------------------------------------

if purchaseButton and purchaseButton:IsA("TextButton") then
	connectButtonWithCooldown(purchaseButton, function()
		if purchaseButton.Text == "PURCHASE" and currentGamepassID then
