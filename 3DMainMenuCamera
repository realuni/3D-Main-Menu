-----------------------------------------
-- Camera follow effect
-----------------------------------------

local function updateCamera()
	local mouseLocation = uis:GetMouseLocation()
	local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
	local offset = (mouseLocation - screenCenter) / screenCenter

	local xOffset = -math.clamp(offset.X, -1, 1) * OFFSET_STRENGTH
	local yOffset = math.clamp(offset.Y, -1, 1) * OFFSET_STRENGTH

	local offsetCFrame = CFrame.Angles(math.rad(-yOffset), math.rad(xOffset), 0)
	local targetCFrame = BASE_CFRAME * offsetCFrame
	camera.CFrame = camera.CFrame:Lerp(targetCFrame, RETURN_SPEED * runService.RenderStepped:Wait())
end

local function setCamera()
	local character = player.Character or player.CharacterAdded:Wait()
	character:WaitForChild("Humanoid")

	camera.CameraType = Enum.CameraType.Scriptable
	camera.CFrame = BASE_CFRAME

	runService:BindToRenderStep("MainMenuCameraFollow", Enum.RenderPriority.Camera.Value + 1, updateCamera)
end


-----------------------------------------
-- Start up
-----------------------------------------

