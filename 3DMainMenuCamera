-----------------------------------------
-- Slide transition function (used Main/Teams/Store buttons)
-----------------------------------------

local function slideTransition(fromFrame, toFrame, reverse)
	fromFrame.Visible = true
	toFrame.Visible = true

	if reverse then
		toFrame.Position = UDim2.new(-1, 0, 0, 0)  -- offscreen LEFT

		local outTween = TweenService:Create(fromFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = UDim2.new(1, 0, 0, 0)  -- slide out RIGHT
		})

		local inTween = TweenService:Create(toFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = UDim2.new(0, 0, 0, 0)  -- slide in CENTER
		})

		tweenFramesWithLock({outTween, inTween}, function()
			fromFrame.Visible = false
			fromFrame.Position = UDim2.new(1, 0, 0, 0)  -- reset offscreen RIGHT
		end)
	else
		toFrame.Position = UDim2.new(1, 0, 0, 0)  -- offscreen RIGHT

		local outTween = TweenService:Create(fromFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = UDim2.new(-1, 0, 0, 0)  -- slide out LEFT
		})

		local inTween = TweenService:Create(toFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = UDim2.new(0, 0, 0, 0)  -- slide in CENTER
		})

		tweenFramesWithLock({outTween, inTween}, function()
			fromFrame.Visible = false
			fromFrame.Position = UDim2.new(-1, 0, 0, 0)  -- reset offscreen LEFT
		end)
	end
end

