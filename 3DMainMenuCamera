-- paste your soundid here
local TYPE_SOUND_ID = "rbxassetid://8816939097"

local function playTypeSound()
	if TYPE_SOUND_ID == "" then return end
	
	local sound = Instance.new("Sound")
	sound.SoundId = TYPE_SOUND_ID
	sound.Volume = 0.25
	sound.PlayOnRemove = false
	sound.Parent = workspace
	sound:Play()

	-- cleanup
	sound.Ended:Connect(function()
		sound:Destroy()
	end)
end

local function typeWriter(label, text)
	for i = 1, #text do
		label.Text = string.sub(text, 1, i)
		playTypeSound()
		task.wait(typeSpeed)
	end
end

task.spawn(function()
	typeWriter(usernameLabel, fullText)
end)

-----------------------------------------
-- Tween helper and global tween lock
-----------------------------------------

local isTweening = false

local function tweenFrame(frame, newPos)
	local tween = TweenService:Create(frame, TweenInfo.new(tweenTime, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Position = newPos
	})
	return tween
end

local function tweenFramesWithLock(tweenList, onComplete)
	isTweening = true
	local completedCount = 0
	local total = #tweenList

	for _, tween in ipairs(tweenList) do
		tween.Completed:Connect(function()
			completedCount = completedCount + 1
			if completedCount >= total then
				isTweening = false
				if onComplete then
					onComplete()
				end
			end
		end)
		tween:Play()
	end
end

